# Application Configuration
# Primary domain for the application
NEXT_PUBLIC_APP_URL=https://dat3night.com

# API Keys for Menu Scraping and Enhanced Pricing
# Add these to your Netlify environment variables

# Yelp Fusion API Key (for menu data)
YELP_API_KEY=your_yelp_api_key_here

# Square API Access Token (for menu data from Square-powered venues)
SQUARE_ACCESS_TOKEN=your_square_access_token_here

# Square Application ID (for identifying Square locations)
SQUARE_APPLICATION_ID=sq0idp-zj_BKLobagkUSKlkMAzUPg

# Existing API Keys
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# Stripe Billing (server)
# Product: DateNight Pro
# Monthly plan: DateNight Pro - Monthly (USD 9.99)
# Yearly plan: DateNight Pro - Yearly (USD 99.99)
STRIPE_SECRET_KEY=sk_live_or_sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_MONTHLY=price_1TH6kyEykVDCxwrv7i14qTAM
STRIPE_PRICE_YEARLY=price_1TH6kyEykVDCxwrva1gKcy0L

# Stripe Billing (client)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_or_pk_test_replace_me

